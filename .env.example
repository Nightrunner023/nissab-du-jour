# Clé d'accès GoldAPI.io — https://www.goldapi.io (gratuit : 100 requêtes/mois)
GOLDAPI_KEY=goldapi-xxxxxxxxxxxxx-io

# Port d'écoute du serveur (défaut : 3000)
PORT=3000

# Champ de prix utilisé :
#   prev_close_price = dernière clôture (recommandé, stable sur 24 h)
#   price            = prix spot au moment de l'appel
PRICE_FIELD=prev_close_price

# Heure du rafraîchissement quotidien, au format cron (défaut : 06:00).
# Exemple minuit : 0 0 * * *
CRON=0 6 * * *
